# Required: Anthropic API key for Claude sentiment analysis
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Default search period in months (default: 12)
# SEARCH_PERIOD_MONTHS=12

# Optional: LLM model to use (default: claude-sonnet-4-6)
# LLM_MODEL=claude-sonnet-4-6

# Optional: Max articles per company per language (default: 50)
# MAX_ARTICLES=50
